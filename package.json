{
  "name": "tender-observer",
  "displayName": "The Tender Observer",
  "description": "A privacy-first ambient companion that observes coding rhythm and offers minimal, gentle interventions.",
  "version": "0.0.2",
  "publisher": "appless-future",
  "keywords": [
    "wellbeing",
    "focus",
    "productivity",
    "ambient",
    "mindful-coding",
    "developer-experience"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/appless-future/tender-observer-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:tenderObserver.openAmbient",
    "onCommand:tenderObserver.openWeeklyRhythmLog",
    "onCommand:tenderObserver.openWeeklySummary",
    "onCommand:tenderObserver.secretMode"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tenderObserver.openAmbient",
        "title": "Tender Observer: Open Ambient View"
      },
      {
        "command": "tenderObserver.secretMode",
        "title": "Tender Observer: Secret Mode (Disperse)"
      },
      {
        "command": "tenderObserver.openWeeklyRhythmLog",
        "title": "Tender Observer: Open Weekly Rhythm Log"
      },
      {
        "command": "tenderObserver.openWeeklySummary",
        "title": "Tender Observer: Open Weekly Summary View"
      }
    ],
    "configuration": {
      "title": "Tender Observer",
      "properties": {
        "tenderObserver.whisperEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable gentle whisper messages."
        },
        "tenderObserver.sensitivity": {
          "type": "string",
          "enum": ["low", "normal", "high"],
          "default": "normal",
          "description": "Detection sensitivity for rhythm states."
        },
        "tenderObserver.nightWhisperEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow whisper messages during late-night hours (2AM-5AM)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run build && node --test --test-isolation=none \"dist/tests/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
